{
  "entities": {
    "Post": {
      "title": "Post",
      "description": "YTÜ Connect feed post made by a student or club",
      "type": "object",
      "properties": {
        "author": {
          "type": "string",
          "description": "Username of the author"
        },
        "authorAvatar": {
          "type": "string",
          "description": "Avatar URL of the author"
        },
        "time": {
          "type": "string",
          "description": "Human-readable time representation (e.g. Şimdi, 2 saat önce)"
        },
        "content": {
          "type": "string",
          "description": "Content text of the post"
        },
        "likes": {
          "type": "integer",
          "description": "Number of likes the post received"
        },
        "field": {
          "type": "string",
          "description": "Interest category or department name"
        },
        "club": {
          "type": "string",
          "description": "Optional club name that posted this"
        },
        "isPinned": {
          "type": "boolean",
          "description": "Whether this post is pinned to the top of the feed"
        },
        "image": {
          "type": "string",
          "description": "Optional Base64 or URL attached image"
        },
        "location": {
          "type": "string",
          "description": "Optional attached campus location"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "ISO timestamp for sorting posts"
        }
      },
      "required": ["author", "content", "likes", "field", "createdAt"]
    },
    "Story": {
      "title": "Story",
      "description": "Temporary 24h campus stories",
      "type": "object",
      "properties": {
        "author": {
          "type": "string",
          "description": "Username of the author"
        },
        "authorAvatar": {
          "type": "string",
          "description": "Avatar URL of the author"
        },
        "content": {
          "type": "string",
          "description": "Text content of the story"
        },
        "gradientClass": {
          "type": "string",
          "description": "Gradient background class combination"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "ISO timestamp when story was created"
        }
      },
      "required": ["author", "content", "createdAt"]
    },
    "RegisteredUser": {
      "title": "RegisteredUser",
      "description": "Registered campus student",
      "type": "object",
      "properties": {
        "studentId": {
          "type": "string",
          "description": "Unique 8-digit school student number"
        },
        "username": {
          "type": "string",
          "description": "User chosen nickname"
        },
        "password": {
          "type": "string",
          "description": "User login password"
        },
        "department": {
          "type": "string",
          "description": "School department of the student"
        },
        "interestedFields": {
          "type": "array",
          "items": { "type": "string" },
          "description": "List of interested categories/fields"
        },
        "interestedClubs": {
          "type": "array",
          "items": { "type": "string" },
          "description": "List of interested clubs"
        },
        "avatar": {
          "type": "string",
          "description": "Avatar image URL or Base64 string"
        },
        "bio": {
          "type": "string",
          "description": "User bio/about me section"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "ISO timestamp of user registration"
        }
      },
      "required": ["studentId", "username", "department", "interestedFields", "interestedClubs", "avatar", "createdAt"]
    }
  },
  "firestore": {
    "/posts/{postId}": {
      "schema": "Post",
      "description": "Collection of community and official posts in the feed"
    },
    "/stories/{storyId}": {
      "schema": "Story",
      "description": "Collection of temporary campus stories"
    },
    "/registered_users/{studentId}": {
      "schema": "RegisteredUser",
      "description": "Collection of registered campus users and student profiles"
    }
  }
}
